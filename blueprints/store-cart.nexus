@React @Tailwind @NestJS @Prisma
Model Producto
  Entity id !pk
  Entity nombre [type:string]
  Entity precio [type:decimal]
  Entity stock [type:integer]
  Entity imagen [type:string]

Model Carrito
  Entity id !pk
  Entity usuario -> Model.Usuario
  Entity items -> Model.Producto [many]
  Entity total [type:decimal]

Controller CarritoController
  @Auth[mode:jwt]
  Router ApiV1
    Endpoint POST /carrito/agregar
      !! "El producto debe tener stock disponible"
      !! producto.stock > 0
      => CarritoService.agregar()
      !error:400 -> /error/sin-stock
      !error:404 -> /error/producto-no-encontrado

    Endpoint DELETE /carrito/:itemId
      !! "El item debe pertenecer al usuario"
      => CarritoService.eliminar()
      !error:403 -> /error/forbidden
      !error:404 -> /error/item-no-encontrado

    Endpoint POST /carrito/checkout
      !! "El carrito no puede estar vacío"
      !! carrito.items.length > 0
      !! "El usuario debe tener dirección registrada"
      => OrdenService.crear()
      !error:400 -> /error/carrito-vacio
      !error:402 -> /error/sin-direccion
