@React @Tailwind
Page Profile
  @Auth[mode:jwt]
  Layout Stack
  Section Header #glass
    Image < user.avatar [ratio:1/1] !round
    Text < user.name !bold !xl
    Text < user.email #muted
    Text < user.role #accent
  Section Settings
    Form ProfileForm
      !! "El nombre no puede estar vacío"
      Input name [type:text] !required
      Input bio [type:textarea]
      Input website [type:url]
      Button "Guardar cambios" => ProfileService.update()
      !error:400 -> /profile?error=invalid
      !error:401 -> /login
