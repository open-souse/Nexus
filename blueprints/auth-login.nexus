@React @Tailwind
Page Login
  @Auth[public]
  Layout Center #glass
  Form LoginForm
    !! "Las credenciales deben ser válidas"
    Input email [type:email] !required
    Input password [type:password] !required
    Button "Iniciar sesión" => AuthService.login()
    !error:401 -> /login?error=invalid
    !error:500 -> /error/server
