@Medical @Protocol:Emergency @Language:es
Protocol TriajeManchester
  $hospital: "Hospital General"
  $prioridad_max: 5
  
  Section "Identificación"
    Field nombre type:string required
    Field edad type:number required
    Field motivo_consulta type:text !bold
  
  Section "Signos Vitales" #prio-1
    Grid [cols:2]
      Field fc type:bpm [min:40, max:180]
      Field fr type:rpm [min:8, max:40]
      Field spo2 type:percent !critical [alert:<92]
      Field temp type:celsius
  
  Section "Evaluación de Dolor"
    Slider escala_eva [min:0, max:10]
    ( escala_eva > 7 ) -> !AlerteRoja : !Normal
  
  Action "Finalizar Clasificación" => API.post(/triage/submit) -> /sala-espera
