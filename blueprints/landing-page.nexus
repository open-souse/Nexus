@React @Tailwind
Page Landing
  @Auth[public]
  Layout Stack
  Section Hero #glass
    Text "El protocolo Humano-IA" !bold !xl
    Text "Elimina la ambigüedad. Escribe intenciones precisas." #muted
    Button "Empezar gratis" => router.push('/register')
    Button "Ver ejemplos" -> /#ejemplos
  Section Features
    List < features [paginate:6]
      Card * 3 #glass
  Section CTA
    Text "¿Listo para empezar?" !bold
    Button "Crear cuenta" #primary => router.push('/register')
