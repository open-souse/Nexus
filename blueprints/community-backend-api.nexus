// COMMUNITY BLUEPRINT — Backend API REST
// Contribución de la comunidad. No validado oficialmente por el equipo NEXUS.
// Adaptar según el framework de backend utilizado (Express, Fastify, NestJS...).

@Node @TypeScript

Endpoint /api/v1/users
  Auth [mode: jwt, role: admin]

  Method GET
    Query [page: number, limit: number, search?: string]
    Response 200 < User * N
    Response 401 < Error "No autorizado"
    Response 500 < Error "Error del servidor"

  Method POST
    Body < CreateUserDTO [validate: true]
    Response 201 < User
    Response 400 < ValidationError
    Response 409 < Error "Usuario ya existe"

Endpoint /api/v1/users/:id
  Auth [mode: jwt]

  Method GET
    Response 200 < User
    Response 404 < Error "Usuario no encontrado"

  Method PATCH
    Body < UpdateUserDTO [partial: true]
    Response 200 < User
    Response 403 < Error "Sin permisos"

  Method DELETE
    Auth [role: admin]
    Response 204
    Response 403 < Error "Sin permisos"

Type CreateUserDTO {
  name: string [min: 2, max: 50]
  email: email [unique: true]
  password: string [min: 8]
  role: "admin" | "user" | "guest"
}

Type UpdateUserDTO {
  name?: string
  email?: email
  bio?: string
}
