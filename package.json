{
  "name": "nxlang",
  "version": "4.1.2",
  "description": "NEXUS: Human-AI language protocol — shorter prompts, precise responses, zero ambiguity",
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "blueprints",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "nexus": "bin/nexus.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "node scripts/test.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "nexus",
    "nxlang",
    "nexus-protocol",
    "human-ai",
    "ai-language",
    "dsl",
    "ai",
    "llm",
    "prompt",
    "structured-language",
    "claude",
    "copilot",
    "cursor",
    "react",
    "typescript",
    "developer-tools",
    "cli"
  ],
  "author": "2026 Ventures SAS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edwinreal/Nexus-.git"
  },
  "homepage": "https://github.com/edwinreal/Nexus-#readme",
  "bugs": {
    "url": "https://github.com/edwinreal/Nexus-/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^12.11.1",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  }
}
