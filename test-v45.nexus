@SDD @NextJS @NestJS
System "Nexus Cloud"
  architecture: Hexagonal
  Actor "Developer"
    can: create-projects, validate-nexus, deploy-apps

Model Project
  Entity id !pk
  Entity name type:string
  Index name [unique]

Controller ProjectController
  policy: is-owner
  Router ProjectApi
    Endpoint POST /create < Payload:ProjectSchema => ProjectService.init()

Page Dashboard
  Section Sidebar
  Section Main
    Table < Project
