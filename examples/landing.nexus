// examples/landing.nexus
@Web #MarketingTheme
Blueprint MarketingLaunch
  Flow: Navbar -> Hero -> Features -> Pricing -> Footer

Page Landing
  Navigate #sticky [style:glass]
    Logo "StartupXYZ"
    Link "Product" -> #features
    Link "Pricing" -> #pricing
    Button "Get Started" #primary

  Component Hero
    Container [align:center, padding-y:100px]
      Text heading "Build your future with NEXUS" !bold
      Text subtitle "The intention-driven language for the AI era."
      Stack [direction:horizontal, gap:15, align:center]
        Button "Try it free" #primary size:large
        Button "Watch Demo" #secondary ?ghost

  Component Features
    Grid [cols:3, gap:30, padding:50px]
      FeatureCard * 3 < [
        "Fast: 80% fewer tokens",
        "Exact: Zero ambiguity",
        "Agnostic: Works everywhere"
      ]

  Component Footer
    Stack [align:between]
      Text "© 2026 NEXUS Lang"
      SocialLinks < ["Twitter", "GitHub", "LinkedIn"]
